<mxfile host="app.diagrams.net" modified="2026-06-12T18:00:00.000Z" agent="claude" version="24.0.0">
  <diagram id="cjm-jtbd-azs" name="CJM / JTBD — АЗС">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="CJM / JTBD «АЗС» — маршруты ролей, happy-path и точки отказа (ссылки на BUG-ID из плана 2026-06-12)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="Легенда:  ⬜ шаг (happy-path)   🟦 JTBD   🟥 точка отказа (баг)   → поток" style="text;html=1;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="900" height="20" as="geometry" />
        </mxCell>

        <!-- ================= LANE 1: Сотрудник АЗС ================= -->
        <mxCell id="lane1" value="Сотрудник АЗС (azs_admin)" style="swimlane;horizontal=0;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=30;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="2120" height="380" as="geometry" />
        </mxCell>
        <mxCell id="l1_jtbd" value="JTBD: «Быстро отчитаться фото, что на АЗС порядок. Если не успеваю — за 10 сек объяснить почему, без захода в приложение.»" style="rounded=1;fillColor=#bbdefb;strokeColor=#1976d2;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="40" width="2050" height="48" as="geometry" />
        </mxCell>

        <mxCell id="l1s1" value="1. Бот прислал задание&#10;(push + кнопки)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="40" y="110" width="160" height="60" as="geometry"/></mxCell>
        <mxCell id="l1s2" value="2. Открыл приложение&#10;(/admin/{id})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="280" y="110" width="160" height="60" as="geometry"/></mxCell>
        <mxCell id="l1s3" value="3. Камера по слотам&#10;снял/переснял" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="520" y="110" width="160" height="60" as="geometry"/></mxCell>
        <mxCell id="l1s4" value="4. Фоновая загрузка фото&#10;(POST /photo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="760" y="110" width="160" height="60" as="geometry"/></mxCell>
        <mxCell id="l1s5" value="5. «Сдать отчёт»&#10;(POST /submit) → done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="1000" y="110" width="160" height="60" as="geometry"/></mxCell>
        <mxCell id="l1a1" value="АЛЬТ. Не успеваю → кнопка бота&#10;«Указать причину»" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane1"><mxGeometry x="1280" y="110" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="l1a2" value="АЛЬТ. Выбрал причину кнопкой&#10;→ «Принято» → CRM «Брак»" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane1"><mxGeometry x="1540" y="110" width="190" height="60" as="geometry"/></mxCell>

        <mxCell id="l1e12" style="endArrow=block;html=1;" edge="1" parent="lane1" source="l1s1" target="l1s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l1e23" style="endArrow=block;html=1;" edge="1" parent="lane1" source="l1s2" target="l1s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l1e34" style="endArrow=block;html=1;" edge="1" parent="lane1" source="l1s3" target="l1s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l1e45" style="endArrow=block;html=1;" edge="1" parent="lane1" source="l1s4" target="l1s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l1ea" style="endArrow=block;html=1;dashed=1;strokeColor=#d6b656;" edge="1" parent="lane1" source="l1a1" target="l1a2"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- failures lane1 -->
        <mxCell id="l1f1" value="🟥 BUG-024: отчёт «не сдан вовремя» через минуту после создания — дедлайн в прошлом" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane1"><mxGeometry x="280" y="240" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="l1f2" value="🟥 LOGIC-F2: фото не льётся → «Сдать» заблокировано, тупик (нет эскейпа)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane1"><mxGeometry x="760" y="240" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="l1f3" value="🟥 LOGIC-R6: причины не настроены → страница причины — тупик" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane1"><mxGeometry x="1280" y="240" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="l1f4" value="🟥 LOGIC-F6: потерял роль → застрял на экране ожидания, нет навигации" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane1"><mxGeometry x="40" y="240" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="l1fe1" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane1" source="l1s4" target="l1f1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l1fe2" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane1" source="l1s4" target="l1f2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l1fe3" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane1" source="l1a1" target="l1f3"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ================= LANE 2: Проверяющий ================= -->
        <mxCell id="lane2" value="Проверяющий (reviewer)" style="swimlane;horizontal=0;fillColor=#d5e8d4;strokeColor=#82b366;startSize=30;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="2120" height="380" as="geometry" />
        </mxCell>
        <mxCell id="l2_jtbd" value="JTBD: «С одного взгляда понять, кто не сдал. Ткнуть проблемное фото и отправить замечание ответственному (управляющий/админ АЗС).»" style="rounded=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="lane2">
          <mxGeometry x="40" y="40" width="2050" height="48" as="geometry" />
        </mxCell>

        <mxCell id="l2s1" value="1. Дашборд: кто сдал/не сдал&#10;(/reports + /summary)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="lane2"><mxGeometry x="40" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l2s2" value="2. Вкладка «Фотолента»&#10;(/photos/feed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="lane2"><mxGeometry x="290" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l2s3" value="3. Открыл фото&#10;(preview, свайпы)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="lane2"><mxGeometry x="540" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l2s4" value="4. Отметил фото&#10;+ свой коммент" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="lane2"><mxGeometry x="790" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l2s5" value="5. Выбрал получателя&#10;(/recipients)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="lane2"><mxGeometry x="1040" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l2s6" value="6. «Отправить (N)»&#10;(POST /photo-remarks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="lane2"><mxGeometry x="1290" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l2s7" value="7. Журнал + повтор&#10;недоставленных" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="lane2"><mxGeometry x="1540" y="110" width="170" height="60" as="geometry"/></mxCell>

        <mxCell id="l2e12" style="endArrow=block;html=1;" edge="1" parent="lane2" source="l2s1" target="l2s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2e23" style="endArrow=block;html=1;" edge="1" parent="lane2" source="l2s2" target="l2s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2e34" style="endArrow=block;html=1;" edge="1" parent="lane2" source="l2s3" target="l2s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2e45" style="endArrow=block;html=1;" edge="1" parent="lane2" source="l2s4" target="l2s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2e56" style="endArrow=block;html=1;" edge="1" parent="lane2" source="l2s5" target="l2s6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2e67" style="endArrow=block;html=1;" edge="1" parent="lane2" source="l2s6" target="l2s7"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="l2f1" value="🟥 BUG-F1: переключил вкладку Дашборд↔Фотолента → весь черновик замечаний потерян" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane2"><mxGeometry x="540" y="240" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="l2f2" value="🟥 LOGIC-F3: ошибка отправки в лайтбоксе невидима (тост под оверлеем)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane2"><mxGeometry x="1290" y="240" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="l2f3" value="🟥 BUG-P2: превью вечно 502 (webhook пуст + токен протух)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane2"><mxGeometry x="540" y="310" width="230" height="50" as="geometry"/></mxCell>
        <mxCell id="l2f4" value="🟥 LOGIC-P7: счётчики дашборда (created_at) ≠ лента (updated_at)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane2"><mxGeometry x="40" y="240" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="l2f5" value="🟥 BUG-P4: фото без diskObjectId выпало из сообщения, но помечено «доставлено»" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane2"><mxGeometry x="1540" y="240" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="l2fe1" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane2" source="l2s4" target="l2f1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2fe2" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane2" source="l2s6" target="l2f2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2fe3" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane2" source="l2s3" target="l2f3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2fe5" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane2" source="l2s7" target="l2f5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ================= LANE 3: Админ ================= -->
        <mxCell id="lane3" value="Администратор (admin)" style="swimlane;horizontal=0;fillColor=#ffe6cc;strokeColor=#d79b00;startSize=30;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="890" width="2120" height="380" as="geometry" />
        </mxCell>
        <mxCell id="l3_jtbd" value="JTBD: «Настроить смарт-процессы, поля, стадии, роли и расписание один раз — и запустить ежедневную авто-рассылку, дальше только смотреть результат.»" style="rounded=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="lane3">
          <mxGeometry x="40" y="40" width="2050" height="48" as="geometry" />
        </mxCell>

        <mxCell id="l3s1" value="1. Открыл настройки&#10;(9 секций)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="lane3"><mxGeometry x="40" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l3s2" value="2. Смарт-процессы, поля,&#10;стадии (вкл. «Брак»)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="lane3"><mxGeometry x="290" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l3s3" value="3. Причины, роли,&#10;чат, расписание" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="lane3"><mxGeometry x="540" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l3s4" value="4. «Сохранить настройки»&#10;(PUT /settings)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="lane3"><mxGeometry x="790" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l3s5" value="5. Сгенерировал план&#10;(POST /plan/generate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="lane3"><mxGeometry x="1040" y="110" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="l3s6" value="6. Авто-рассылка по времени&#10;+ мониторинг ленты" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="lane3"><mxGeometry x="1290" y="110" width="170" height="60" as="geometry"/></mxCell>

        <mxCell id="l3e12" style="endArrow=block;html=1;" edge="1" parent="lane3" source="l3s1" target="l3s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3e23" style="endArrow=block;html=1;" edge="1" parent="lane3" source="l3s2" target="l3s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3e34" style="endArrow=block;html=1;" edge="1" parent="lane3" source="l3s3" target="l3s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3e45" style="endArrow=block;html=1;" edge="1" parent="lane3" source="l3s4" target="l3s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3e56" style="endArrow=block;html=1;" edge="1" parent="lane3" source="l3s5" target="l3s6"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="l3f1" value="🟥 BUG-A1/A2: «Сохранить» не работает — админ разжалован (getToken ADMIN=false) или не userId 498" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane3"><mxGeometry x="790" y="240" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="l3f2" value="🟥 BUG-A3: сейв падает целиком при сбое Bitrix app.option (БД не пишет)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane3"><mxGeometry x="790" y="310" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="l3f3" value="🟥 BUG-S1/S2: /install и /bot/event без верификации (application_token/JOB_SECRET)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane3"><mxGeometry x="40" y="240" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="l3f4" value="🟥 BUG-024: рассылка создаёт отчёты уже просроченными (дедлайн от планового слота)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane3"><mxGeometry x="1290" y="240" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="l3f5" value="🟥 BUG-P6/P8: multi-portal контекст; парк &gt;1000 АЗС не получает рассылку" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane3"><mxGeometry x="1040" y="240" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="l3fe1" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane3" source="l3s4" target="l3f1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3fe3" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane3" source="l3s1" target="l3f3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3fe4" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane3" source="l3s6" target="l3f4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3fe5" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="lane3" source="l3s5" target="l3f5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- cross-lane handoffs -->
        <mxCell id="x_admin_to_azs" value="рассылка → задание сотруднику" style="endArrow=block;html=1;dashed=1;strokeColor=#9673a6;fontSize=10;" edge="1" parent="1" source="l3s6" target="l1s1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="x_azs_to_rev" value="сдал/не сдал → виден проверяющему" style="endArrow=block;html=1;dashed=1;strokeColor=#9673a6;fontSize=10;" edge="1" parent="1" source="l1s5" target="l2s1"><mxGeometry relative="1" as="geometry"/></mxCell>
