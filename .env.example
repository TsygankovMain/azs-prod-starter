JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256

CLOUDPUB_TOKEN='your_cloudpub_token_here'
CLIENT_ID='bitrix_application_client_id'
CLIENT_SECRET='bitrix_application_client_secret'
SCOPE='crm,disk,im,imbot,user,user_brief,pull,placement,userfieldconfig'

## Domain #######################################
# for http://frontend:3000 ####
# enter here URL of your FRONTEND && BACKEND application
# there should be a URL that you enter in the application settings in Bitrix24
VIRTUAL_HOST='https://your_cloudpub_sub_domain_1.cloudpub.ru'

# http://api-php:8000
# http://api-python:8000
# http://api-node:8000
# enter here BACKEND type
SERVER_HOST='http://api-some:8000'
BITRIX_REST_ENDPOINT='https://your-portal.bitrix24.ru/rest'
BITRIX_REST_AUTH_ID='oauth_or_webhook_token'

# Hard HTTP timeout for every fetch() call to the Bitrix REST / OAuth endpoint
# Guards against infinite hangs during Bitrix slowdowns.
# Timed-out requests are treated as transient errors and automatically retried.
# Default: 30000 (30 s). Lower for stricter SLOs, raise if you hit false positives.
# BITRIX_HTTP_TIMEOUT_MS=30000
# Separate timeout for binary file downloads (disk.file downloadFileContent).
# Downloading photo attachments on a slow network takes longer than REST calls.
# Default: 120000 (120 s).
# BITRIX_HTTP_DOWNLOAD_TIMEOUT_MS=120000

# Pre-emptive OAuth refresh: detects refresh_tokens nearing the 30-day Bitrix
# TTL and forces a refresh before silent death. Hourly cron by default.
TOKEN_REFRESH_SCHEDULER_ENABLED=true
TOKEN_REFRESH_CRON='0 * * * *'

# Durable CRM sync worker (persists per-report sync jobs, survives restarts)
CRM_SYNC_WORKER_ENABLED=true
CRM_SYNC_POLL_MS=1000
# How old (ms) a 'running' job must be before recover() reclaims it on startup.
# Guards against rolling-deploy race: a job younger than this threshold is likely
# still being processed by the old pod and must not be stolen. Default: 5 minutes.
CRM_SYNC_STALE_RUNNING_MS=300000

# Randomized dispatch plan (plan-then-execute). ON by default.
# At DISPATCH_PLAN_GENERATION_CRON a per-AZS randomized plan is built (each AZS
# gets its own jittered time, clamped to settings report.workWindow), and the
# per-minute tick fires each AZS at its own time so stations can't predict the
# check. Requires SCHEDULER_ENABLED=true.
# Set to false to fall back to the legacy "send all at the slot minute" behavior.
DISPATCH_PLAN_MODE_ENABLED=true
DISPATCH_PLAN_GENERATION_CRON='1 0 * * *'
DISPATCH_EXECUTE_BATCH_LIMIT=20

# Resilience: inbound webhook for BACKGROUND tasks (plan generation + dispatch +
# reading/writing the Bitrix plan mirror). Lets automation work AFTER a redeploy
# even when no admin has opened the app (the per-user OAuth file is gone).
# Create an inbound webhook in the portal (scope: crm, im, imbot, disk, user)
# and paste its URL here. Empty → falls back to the admin OAuth context (legacy).
# The dispatch plan is also mirrored to Bitrix app.option so it survives a
# redeploy that wipes the DB; the DB is rehydrated from the mirror on read.
BITRIX_WEBHOOK_URL=

BITRIX_BOT_MODE='notify'
BITRIX_BOT_ID='0'
BITRIX_BOT_CODE='azs_order_bot'
BITRIX_BOT_NAME='Порядок на АЗС'
BITRIX_APP_CODE='local.00000000000000.00000000'
APP_PUBLIC_BASE_URL='https://your_cloudpub_sub_domain_1.cloudpub.ru'

# Deep-link button in bot dispatch notifications (needs mobile app update; off by default)
ENABLE_REPORT_DEEP_LINK=false

# Database
DB_TYPE=postgresql
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=apppass
DB_ROOT_PASSWORD=rootpass
DB_PORT=5432
DATABASE_URL=postgresql://appuser:apppass@database:5432/appdb?serverVersion=17&charset=utf8

# Auth-context store backend (controls where OAuth tokens survive redeploys).
# composite (default) — DB primary, file fallback, auto-seeds DB from file on
#   first startup when DB is empty. Most resilient — no operator action needed.
# database — DB only; use after a successful composite run confirms all tokens
#   have been migrated and the file can be dropped.
# file — legacy file-only mode (data/auth-context.json); NOT redeploy-safe;
#   scheduler goes silent until admin reopens the app after every redeploy.
AUTH_CONTEXT_STORE=composite

# CloudPub image settings
CLOUDPUB_IMAGE=cloudpub/cloudpub:latest
CLOUDPUB_PLATFORM=linux/amd64

# RabbitMQ (queues)
ENABLE_RABBITMQ=0
RABBITMQ_USER=queue_user
RABBITMQ_PASSWORD=queue_password
RABBITMQ_PREFETCH=5
RABBITMQ_DSN=amqp://queue_user:queue_password@rabbitmq:5672/%2f

# BUILD_TARGET dev | production
BUILD_TARGET=dev

## SYSTEM ######################################
# Don't change unless absolutely necessary
# need sync with docker
VIRTUAL_PORT=3000
#NUXT_APP_INTERNAL_URL='http://frontend:3000'
#NUXT_ALLOWED_IPS='127.0.0.1,::1'
#PGPORT=5432
PORT=3000
HOST=0.0.0.0
NODE_ENV='development'
## MEMO: don't use `DEV=true` -> it will break @bitrix24/ui

#Django admin panel for python api (api/admin)
DJANGO_SUPERUSER_USERNAME="admin"
DJANGO_SUPERUSER_EMAIL="admin@example.com"
DJANGO_SUPERUSER_PASSWORD="password"

###> OpenTelemetry ###
# Единая точка включения/выключения телеметрии для backend и frontend.
# Используется PHP-бэкендом (TELEMETRY_ENABLED) и Nuxt-фронтом (NUXT_PUBLIC_TELEMETRY_ENABLED).
# OTel Collector должен быть запущен через b24-ai-starter-otel: cd ../b24-ai-starter-otel && make up
TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <generate-your-token>
OTEL_SERVICE_NAME=b24-app
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=development
# Профиль телеметрии: simple-ui | integration-sync | integration-with-migration | migrator-light | migrator-advanced | development
OTEL_TELEMETRY_PROFILE=simple-ui
###< OpenTelemetry ###
